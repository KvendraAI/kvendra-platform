# Kvendra Platform — environment configuration template
# Copy to .env for local dev (NOT committed). docker-compose injects its own.

# PostgreSQL connection string (Postgres 16 + pgvector extension required).
DATABASE_URL=postgres://kvendra:kvendra@localhost:5432/kvendra_platform

# Embeddings provider. M1 only supports `mock` (deterministic 1024-dim).
# Future: bedrock | openai | ollama | http (per ADR-KVD-024 / ROAD-KVD-011 M2).
EMBEDDINGS_PROVIDER=mock

# Path to the auth token file. The token gates `tools/call` invocations.
# The entrypoint script bootstraps this file with `openssl rand -hex 32`.
AUTH_TOKEN_FILE=/data/auth.token

# Fastify listen port (7777 chosen to avoid conflicts with common dev ports).
PORT=7777
HOST=0.0.0.0

# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Deployment stage: local | staging | prod
STAGE=local

# Optional: override Postgres connection pool size.
PG_POOL_MAX=10
